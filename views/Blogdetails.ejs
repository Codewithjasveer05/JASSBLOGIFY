<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
</head>

<body>

    <%- include('./partials/navbar') %>

        <div class="container mt-4">

            <!-- Blog Image -->
      <img src="<%= blog.coverImgUrl %>" class="img-fluid rounded" alt="">

            <!-- Blog Title -->
            <h1 class="mt-4">
                <%= blog.title %>
            </h1>

            <!-- Blog Body -->
            <p class="mt-3" style="white-space: pre-line;">
                <%= blog.body %>
            </p>

        </div>

        <!-- Author Section -->
        <div class="container mt-5">
            <div class="card p-3 shadow-sm">

                <h4>About the Author</h4>

                <div class="d-flex align-items-center mt-3">

                    <img src="<%= blog.createdBy.profileImg %>" width="60" height="60" class="rounded-circle" alt="">

                    <div class="ms-3">
                        <h5 class="mb-1">
                            <%= blog.createdBy.name %>
                        </h5>
                        <p class="text-muted mb-0">
                            Author of this blog
                        </p>
                    </div>
                </div>

            </div>
        </div>

        <!-- Comments Section -->
        <div class="container mt-3">
            <h1>Comments</h1>

            <% if (locals.user) { %>
            <form action="/blog/<%= blog._id %>/comment" method="POST">
                <div class="mb-3">
                    <input type="text" name="content" class="form-control" placeholder="Enter your comment" required/>
                    <button class="btn btn-sm btn-primary mt-2" type="submit">Add</button>
                </div>
            </form>
            <% } %>

            <hr>

            <% comments.forEach(comment => { %>

                <div class="d-flex align-items-start mt-4">

                    <img
                        src="<%= comment.createdBy.profileImg %>"
                        width="45"
                        height="45"
                        class="rounded-circle"
                        alt=""
                    >

                    <div class="ms-3">
                        <h5 class="mb-1">
                            <%= comment.createdBy.name %>:
                        </h5>
                        <p class="mb-0">
                            <%= comment.content %>
                        </p>
                    </div>

                </div>

            <% }) %>

        </div>

        <%- include('./partials/script') %>

</body>

</html>