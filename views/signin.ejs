<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
</head>
<body>

<%- include('./partials/navbar') %>

<div class="container mt-5">

  <% if(locals.error){ %>
    <div class="alert alert-danger">
      <%= error %>
    </div>
  <% } %>

  <form action="/user/signin" method="POST">

    <div class="mb-3">
      <label>Email</label>
      <input
        type="email"
        name="email"
        class="form-control"
        required
      >
    </div>

    <div class="mb-3">
      <label>Password</label>
      <input
        type="password"
        name="password"
        class="form-control"
        required
      >
    </div>

    <button class="btn btn-primary">
      Login
    </button>

  </form>

</div>

<%- include('./partials/script') %>

</body>
</html>